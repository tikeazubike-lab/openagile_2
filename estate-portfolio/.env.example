# =============================================================
# Estate Portfolio - Environment Variables
#
# DB uses SHARED OpenAgile postgres (openagile_postgres container)
# DB_HOST must match the container name on openagile_openagile_network
# DB_PASSWORD must match POSTGRES_PASSWORD in the root openagile stack
# =============================================================

DB_HOST=openagile_postgres
DB_NAME=estate_portfolio
DB_USER=openagile
DB_PASSWORD=your_shared_postgres_password_here

# EODHD.com API Key for fetching NGX stock prices
# NOTE: XNSA (Nigerian Exchange) requires the paid All-World plan ($19.99/mo)
#   Free tier (20 calls/day) does NOT include XNSA exchange — returns HTTP 402
#   Registration: https://eodhd.com/register
EODHD_API_KEY=your_eodhd_api_key_here

# REMOVED: RAPIDAPI_KEY — the yahoo-finance15 RapidAPI provider does not support
#   NGX tickers (.LG / .XNSA format). Scraper is deprecated and disabled in UI.
