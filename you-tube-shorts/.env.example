# ============================================
# YouTube Shorts Pipeline — Environment Variables
# Copy to .env and fill in actual values
# ============================================

# --- Kokoro TTS ---
# Kokoro TTS is deployed alongside this project.
# Internal Docker URL (used by N8N): http://kokoro-tts:8880/v1/audio/speech
# No env vars needed for Kokoro itself — it's zero-config.

# --- OpenCLAW Gateway ---
# Internal Docker URL: http://openclaw-gateway:18789/v1/chat/completions
OPENCLAW_API_URL=http://openclaw-gateway:18789/v1/chat/completions
OPENCLAW_GATEWAY_TOKEN=your_gateway_auth_token_here

# --- Direct LLM REST API (Python Fallback / Default) ---
# Used natively by main.py to bypass Docker memory limits completely
LLM_API_KEY=your_zhipu_or_openai_api_key_here
LLM_BASE_URL="https://openrouter.ai/api/v1/chat/completions"
LLM_MODEL="nvidia/nemotron-3-super-120b-a12b:free"

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- YouTube API ---
# These are paths INSIDE the pipeline directory on the server
YOUTUBE_CREDENTIALS_PATH=/home/zubbyik/shorts-pipeline/youtube_credentials.json
YOUTUBE_TOKEN_PATH=/home/zubbyik/shorts-pipeline/youtube_token.pickle

# --- Pipeline Directories ---
# Base directory for pipeline data on the server
PIPELINE_BASE_DIR=/home/zubbyik/shorts-pipeline
CLIPS_DIR=${PIPELINE_BASE_DIR}/clips
AUDIO_DIR=${PIPELINE_BASE_DIR}/audio
OUTPUT_DIR=${PIPELINE_BASE_DIR}/output
LOGS_DIR=${PIPELINE_BASE_DIR}/logs

# --- Optional: Traefik Exposure ---
# Uncomment to expose Kokoro TTS via Traefik (not required for internal use)
# TTS_DOMAIN=tts.zubbystudio.shop
