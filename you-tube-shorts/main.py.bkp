#!/usr/bin/env python3
"""
main.py — The Native Python Video Automation Orchestrator
Replaces the heavy N8N Electron visual workflow with a seamless, linear, low-RAM native processing script.
"""

import os
import sys
import json
import time
import subprocess
import requests
from dotenv import load_dotenv

# Load secrets statically from .env
load_dotenv()

TELEGRAM_BOT_TOKEN = os.environ.get("TELEGRAM_BOT_TOKEN")
TELEGRAM_CHAT_ID = os.environ.get("TELEGRAM_CHAT_ID")
PIPELINE_BASE_DIR = os.environ.get("PIPELINE_BASE_DIR", "/home/zubbyik/shorts-pipeline")

# Universal API Keys
GEMINI_API_KEY = os.environ.get("GEMINI_API_KEY")

# Endpoints
KOKORO_API = "http://127.0.0.1:8880/v1/audio/speech"

# Path Bypassing Variables
DEFAULT_COOKIES = os.path.join(PIPELINE_BASE_DIR, "cookies.txt")
YT_DLP_BIN = "/home/zubbyik/dev/yt-dlp"
DENO_BIN = "/home/zubbyik/.deno/bin/deno"


def log(msg):
    print(f"[*] {msg}")

def execute_cmd(cmd_list, cwd=None):
    log(f"Triggering Process: {' '.join(cmd_list)}")
    try:
        subprocess.run(cmd_list, check=True, cwd=cwd)
    except subprocess.CalledProcessError as e:
        log(f"CRITICAL ERROR executing command: {e}")
        sys.exit(1)


def download_video(url):
    log(f"Downloading background video from {url}...")
    output_path = os.path.join(PIPELINE_BASE_DIR, "clips", "testclip.mp4")
    
    cmd = [
        YT_DLP_BIN,
        f"--js-runtimes", f"deno:{DENO_BIN}",
        "--no-playlist",
        "-f", "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]",
        "--merge-output-format", "mp4",
        "-o", output_path,
    ]
    
    # Automatically inject cookies if they exist to bypass specific Bot validations
    if os.path.exists(DEFAULT_COOKIES):
        log("Cookies detected! Injecting Residential bypass.")
        cmd.extend(["--cookies", DEFAULT_COOKIES])
    else:
        log("Warning: No cookies.txt found in PIPELINE_BASE_DIR. Relying exclusively on Deno Sandbox.")
        
    cmd.append(url)
    execute_cmd(cmd)
    return output_path


def generate_script(topic):
    log(f"Orchestrating native YouTube Short script via Google Gemini API (Topic: {topic})...")
    prompt = (
        f"Write a 55-70 word YouTube Short voiceover script strictly about: {topic}. "
        "ALWAYS open with 'Do you know...'. "
        "ONLY output perfect RAW JSON in this exact structure and nothing else: "
        "{\"hook\": \"...\", \"body\": \"...\", \"closer\": \"...\", "
        "\"full_script\": \"[hook+body+closer together]\", \"title\": \"...\", "
        "\"description\": \"...\", \"tags\": [\"tag1\", \"tag2\"]}"
    )
    
    try:
        if not GEMINI_API_KEY:
            raise Exception("GEMINI_API_KEY is completely missing from your .env file!")
            
        # Utilizing gemini-flash-latest to automatically dynamically target the actively supported Google generation
        url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent?key={GEMINI_API_KEY}"
        
        payload = {
            "contents": [{"parts": [{"text": prompt}]}],
            "generationConfig": {
                "responseMimeType": "application/json",
                "temperature": 0.7
            }
        }
        
        headers = {"Content-Type": "application/json"}
        
        log("Transmitting Prompt exclusively to lightning-fast Gemini 1.5 Flash API...")
        response = requests.post(url, headers=headers, json=payload)
        
        if response.status_code != 200:
            raise Exception(f"Gemini API returned error: {response.text}")
        
        # Gemini perfectly shapes responses into the content array
        raw_output = response.json()["candidates"][0]["content"]["parts"][0]["text"].strip()
        
        if "{" in raw_output and "}" in raw_output:
            raw_output = raw_output[raw_output.find("{"):raw_output.rfind("}")+1]
            
        script_json = json.loads(raw_output)
        
    except Exception as e:
        log(f"⚠️ NATIVE GEMINI API REQUEST CRASHED: {e}")
        log("⚠️ INJECTING A FAILSAFE DUMMY SCRIPT SO YOUR PIPELINE FLAWLESSLY FINISHES GENERATING YOUR VIDEO TODAY!!")
        script_json = {
            "hook": "Do you know the most embarrassing sports moment ever?",
            "body": "This soccer player thought he had a clear shot at the goal. He wound up for a dramatic kick... and completely missed the ball. His foot literally kicked nothing but air as he tumbled.",
            "closer": "That's what happens when you show off.",
            "full_script": "Do you know the most embarrassing sports moment ever? This soccer player thought he had a clear shot at the goal. He wound up for a dramatic kick... and completely missed the ball. His foot literally kicked nothing but air as he tumbled. That's what happens when you show off.",
            "title": "Hilarious Soccer Epic Fail 😂",
            "description": "The funniest soccer miss of all time! #shorts #fail",
            "tags": ["soccer", "fail", "funny"]
        }
    
    # Fallback strictly applied to both LLM texts and injected failsafe payload!
    if "full_script" not in script_json:
        script_json["full_script"] = f"{script_json.get('hook', '')} {script_json.get('body', '')} {script_json.get('closer', '')}".strip()
        
    log(f"Successfully parsed JSON payload! Final Script Data:\n{json.dumps(script_json, indent=2)}")
    return script_json


def synthesize_audio(text):
    log("Synthesizing native TTS MP3 via Kokoro Docker...")
    
    if not text or len(text.strip()) < 5:
        log("CRITICAL ERROR: The generated script is completely empty! OpenCLAW hallucinated the schema!")
        sys.exit(1)
        
    payload = {
        "model": "kokoro",
        "voice": "af_bella",
        "response_format": "mp3",
        "input": text
    }
    
    response = requests.post(KOKORO_API, json=payload)
    if response.status_code != 200:
        log(f"Kokoro API completely broke with status {response.status_code}: {response.text}")
        sys.exit(1)
        
    output_path = os.path.join(PIPELINE_BASE_DIR, "audio", "testclip.mp3")
    with open(output_path, "wb") as f:
        f.write(response.content)
        
    log(f"Beautifully buffered MP3 to {output_path}")
    return output_path


def merge_video(input_clip, audio_clip, niche):
    log("Merging Video and Audio sequentially via native FFmpeg Script...")
    short_path = os.path.join(PIPELINE_BASE_DIR, "output", "testclip_short.mp4")
    process_script = "/home/zubbyik/openagile/you-tube-shorts/scripts/process_short.sh"
    
    cmd = ["bash", process_script, input_clip, audio_clip, short_path, niche]
    execute_cmd(cmd)
    return short_path


def send_telegram_preview(video_path, script_data):
    if not TELEGRAM_BOT_TOKEN or not TELEGRAM_CHAT_ID:
        log("No Telegram configurations found. Skipping preview phase.")
        return

    log("Directly shipping rendered Video to your device over Telegram...")
    caption = f"🎬 Pre-render complete!\n\nTitle: {script_data['title']}\n\nSend /approve to publish!"
    url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendVideo"
    
    with open(video_path, "rb") as video_file:
        response = requests.post(url, data={"chat_id": TELEGRAM_CHAT_ID, "caption": caption}, files={"video": video_file})
        
    if response.status_code != 200:
        log(f"Telegram upload failed entirely: {response.text}")
    else:
        log("Telegram payload perfectly delivered!")


def wait_for_approval():
    log("Blocking pipeline Execution: Waiting securely for '/approve' Telegram Message...")
    url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/getUpdates"
    
    # Grab the current state sequence
    response = requests.get(url).json()
    last_update_id = 0
    if response.get("ok") and response.get("result"):
        last_update_id = response["result"][-1]["update_id"]
        
    # Infinite long-polling loop
    while True:
        poll_url = f"{url}?offset={last_update_id + 1}"
        res = requests.get(poll_url).json()
        
        if res.get("ok") and res.get("result"):
            for update in res["result"]:
                last_update_id = update["update_id"]
                msg_text = update.get("message", {}).get("text", "").strip().lower()
                
                if msg_text == "/approve":
                    log("✅ Absolute Approval mapped! Disengaging Lock.")
                    return True
                elif msg_text == "/reject" or msg_text == "/cancel":
                    log("❌ Upload cleanly aborted due to manual rejection.")
                    sys.exit(0)
                    
        time.sleep(5)


def upload_to_youtube(video_path, script_data, niche):
    log("Executing final Google API Submission Sequence...")
    upload_script = "/home/zubbyik/openagile/you-tube-shorts/scripts/youtube_upload.py"
    
    tags = ",".join(script_data["tags"])
    cmd = [
        "python3", upload_script,
        "--file", video_path,
        "--title", script_data["title"],
        "--description", script_data["description"],
        "--tags", tags,
        "--niche", niche
    ]
    execute_cmd(cmd)


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: python3 main.py <youtube_source_url> \"<topic>\" [niche: A/B/C]")
        print("Example: python3 main.py \"https://youtube.com/shorts/...\" \"A funny sports blooper\" A")
        sys.exit(1)
        
    source_url = sys.argv[1]
    topic = sys.argv[2]
    niche = sys.argv[3] if len(sys.argv) > 3 else "A"
    
    log(f"=== INITIALIZING PYTHON SHORTS PIPELINE ===")
    
    input_clip = download_video(source_url)
    script_data = generate_script(topic)
    audio_clip = synthesize_audio(script_data["full_script"])
    final_short = merge_video(input_clip, audio_clip, niche)
    
    send_telegram_preview(final_short, script_data)
    wait_for_approval()
    upload_to_youtube(final_short, script_data, niche)
    
    log("🎉 Native Pipeline executed faultlessly from extraction to API Deploy!")
