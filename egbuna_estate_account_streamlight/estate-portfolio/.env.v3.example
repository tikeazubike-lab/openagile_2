# ═══════════════════════════════════════════════════════════════════════════════
# EPM Phase 3 — Environment Variables Template
# Copy this to .env.v3 on the server, fill in all values.
# DO NOT commit .env.v3 to git — it contains secrets.
#
# Server path: /home/zubbyik/openagile_2/egbuna_estate_account_streamlight/estate-portfolio/.env.v3
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
# Uses the SHARED openagile_postgres container.
# Must use postgresql+asyncpg:// scheme for SQLAlchemy async engine.
# DB_HOST must be the container name visible on openagile_openagile_network.
DATABASE_URL=postgresql+asyncpg://openagile:YOUR_SHARED_POSTGRES_PASSWORD@openagile_postgres/estate_portfolio

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong random secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERATE_A_STRONG_RANDOM_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Must include the exact Traefik-routed domain (no trailing slash).
ALLOWED_ORIGINS=https://testdrive.epm.zubbystudio.shop

# ── App Environment ───────────────────────────────────────────────────────────
# Set to "development" to enable Swagger UI (/api/docs) and SQL logging.
APP_ENV=production

# ── Admin User (seed script) ──────────────────────────────────────────────────
# Used by scripts/seed_admin.py (run via GitHub Actions on first deploy).
# The GitHub secret EPM_ADMIN_PASSWORD is passed as an env var to docker exec.
# Do NOT set this here — it is injected by the GitHub Actions workflow.
# EPM_ADMIN_USERNAME=zubbyik
# EPM_ADMIN_NAME=Zubby
# EPM_ADMIN_PASSWORD=<injected by GitHub Actions>
